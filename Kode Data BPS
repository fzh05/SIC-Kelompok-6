].astype(str)\n","\n","# Create a clean list of new column names from this row\n","new_cols = []\n","for i, col_val in enumerate(actual_header_row):\n","    c = str(col_val).strip()\n","    if c == \"No.\":\n","        new_cols.append(\"No\")\n","    elif c == \"Lapangan Pekerjaan Utama\":\n","        new_cols.append(\"Main_Industry\")\n","    elif c == \"nan\" or c == \"\": # Handle explicit 'nan' string or empty cells in header\n","        new_cols.append(f\"Unnamed_Header_{i}\") # Assign temp name for truly empty header cells\n","    else:\n","        # For year columns like '1995***)', remove '***)' and strip whitespace\n","        # Use regex to extract only the 4-digit year if present, otherwise keep as is\n","        match = re.search(r\"(\\d{4})\", c)\n","        if match:\n","            new_cols.append(match.group(1)) # Extract the year\n","        else:\n","            new_cols.append(c)\n","\n","# Data starts from df_raw.iloc[4] (skipping the main title (0), empty row (1), headers (2), and 'Jumlah' row (3))\n","df = df_raw.iloc[4:].copy()\n","df.columns = new_cols # Apply the cleaned headers\n","df = df.reset_index(drop=True)\n","\n","# Drop any rows that are entirely NaN, which might still be present if data was sparse\n","df = df.dropna(how='all')\n","\n","df = df.dropna(axis=1, how=\"all\")\n","\n","\n","#KONVERSI NUMERIC\n","id_vars = [\"No\", \"Main_Industry\"]\n","# Identify year columns, they are expected to be purely digits after cleaning in step 1.\n","# Ensure to only select columns that actually exist in the DataFrame after drops.\n","existing_year_cols = [col for col in df.columns if str(col).isdigit() and col not in id_vars]\n","\n","for col in existing_year_cols: # Iterate only over identified year columns\n","    df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n","\n","\n","# MELT (FIXED)\n","df_long = df.melt(\n","    id_vars=id_vars,\n","    value_vars=existing_year_cols, # Use the correctly identified year columns\n","    var_name=\"Year\",\n","    value_name=\"Workers\"\n",")\n","\n","df_long[\"Year\"] = pd.to_numeric(df_long[\"Year\"], errors=\"coerce\")\n","df_long[\"Workers\"] = pd.to_numeric(df_long[\"Workers\"], errors=\"coerce\")\n","\n","df_long = df_long.dropna(subset=[\"Year\", \"Workers\", \"Main_Industry\"])\n","\n","\n","# 7. CEK HASIL\n","print(df_long.head())\n","print(df_long.shape)\n","print(df_long.info())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZQF0h163lmKq","executionInfo":{"status":"ok","timestamp":1781785815198,"user_tz":-420,"elapsed":268,"user":{"displayName":"002_ Afifah Fauziah","userId":"08934661557498639369"}},"outputId":"87f23ff1-6552-4c12-e5e6-72073d484f7a"},"execution_count":67,"outputs":[{"output_type":"stream","name":"stdout","text":["  No                                      Main_Industry  Year     Workers\n","0  1  Pertanian, Perkebunan, Kehutanan, Perburuan, d...  1986  35543142.0\n","1  2                        Pertambangan dan Penggalian  1986         0.0\n","2  3                                           Industri  1986   5389177.0\n","3  4                        Listrik, Gas, dan Air Minum  1986         0.0\n","4  5                                         Konstruksi  1986         0.0\n","(816, 4)\n","<class 'pandas.core.frame.DataFrame'>\n","Index: 816 entries, 0 to 1212\n","Data columns (total 4 columns):\n"," #   Column         Non-Null Count  Dtype  \n","---  ------         --------------  -----  \n"," 0   No             763 non-null    object \n"," 1   Main_Industry  816 non-null    object \n"," 2   Year           816 non-null    int64  \n"," 3   Workers        816 non-null    float64\n","dtypes: float64(1), int64(1), object(2)\n","memory usage: 31.9+ KB\n","None\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","\n","def print_table(df, title=\"HASIL\"):\n","    print(\"\\n\" + \"=\" * 60)\n","    print(title)\n","    print(\"=\" * 60)\n","    print(df.to_string(index=False))\n","    print(\"=\" * 60 + \"\\n\")\n